# ══════════════════════════════════════════════════════════════════
# FINTECH PIPELINE — Variables de Entorno
# Copia este archivo como .env y completa con tus credenciales reales
# NUNCA subas el archivo .env a Git
# ══════════════════════════════════════════════════════════════════

# ── LLM LOCAL (Ollama — REQUERIDO para el agente) ─────────────────
# Ollama debe estar corriendo en localhost:11434
# Instalar: https://ollama.com/download
# Modelo recomendado: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── AWS S3 (para subir Parquets) ───────────────────────────────────
AWS_ACCESS_KEY_ID=tu_access_key_aqui
AWS_SECRET_ACCESS_KEY=tu_secret_key_aqui
# Solo si usas credenciales temporales de AWS STS / AWS Academy / SSO
# AWS_SESSION_TOKEN=tu_session_token_temporal
AWS_REGION=us-east-1
AWS_BUCKET=tu-bucket-fintech

# ── DATABRICKS (Unity Catalog — Catálogo Fintech) ──────────────────
# Host: sin https://, sin / al final
DATABRICKS_HOST=dbc-cd89db62-9f56.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/XXXXXXXXXXXXXXXX
DATABRICKS_CATALOG=fintech_pipeline
DATABRICKS_SCHEMA=fintech

# ── APIs EXTERNAS DE ENRIQUECIMIENTO ───────────────────────────────
EXCHANGE_RATE_API_KEY=tu_clave_exchangerate_aqui
# ip-api.com no requiere clave para bajo volumen; el pipeline no usa API key
